# Humboldt-Probe standalone installer (Linux) -- optional MQTT broker override.
#
# Defaults (used when this file is absent or the lines stay commented out):
#   MQTT_HOST=srv-control-avm
#   MQTT_PORT=8883
#
# To point at a different broker, uncomment and edit:
#MQTT_HOST=srv-control-avm
#MQTT_PORT=8883
#
# Optional: pin an explicit MQTT identity (client_id + topic prefix) when
# socket.getfqdn() returns the bare hostname on this box (multi-NIC / no DNS
# suffix). Must match the FQDN the manager expects. Leave unset otherwise.
#CLIENT_ID=kosmo-cm-02.kosmo
